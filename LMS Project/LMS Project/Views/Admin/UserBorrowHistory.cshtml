@using LMS_Project.Models
@model IEnumerable<BorrowRecord>

@{
    ViewData["Title"] = "Lịch Sử Mượn Sách";
    var user = ViewBag.TargetUser as User;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold"><i class="bi bi-clock-history me-2"></i>Lịch Sử Mượn Sách</h2>
        <p class="text-muted mb-0">
            Người dùng: <strong>@user?.FullName</strong>
            <span class="text-muted mx-1">|</span>
            <small>@user?.Email</small>
        </p>
    </div>
    <a asp-controller="Admin" asp-action="Index" asp-route-tab="users" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay Lại
    </a>
</div>

<!-- Thống kê nhanh -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-journal-bookmark display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@Model.Count()</div>
                    <small>Tổng Lượt Mượn</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-bookmark-check display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@Model.Count(b => b.Status == BorrowStatus.Approved)</div>
                    <small>Đang Mượn</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-secondary shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-check2-circle display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@Model.Count(b => b.Status == BorrowStatus.Returned)</div>
                    <small>Đã Trả</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-danger shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-circle display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@Model.Count(b => b.Status == BorrowStatus.Late)</div>
                    <small>Quá Hạn</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bảng lịch sử -->
<div class="card shadow-sm">
    <div class="card-header fw-semibold">
        <i class="bi bi-list-ul me-2"></i>Chi Tiết Lịch Sử
    </div>
    <div class="card-body table-responsive p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x display-4 d-block mb-2"></i>
                Người dùng này chưa có lịch sử mượn sách.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Sách</th>
                        <th>Ngày Mượn</th>
                        <th>Hạn Trả</th>
                        <th>Ngày Trả</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{int row = 1;}
                    @foreach (var br in Model)
                    {
                        <tr>
                            <td>@(row++)</td>
                            <td>
                                <div class="fw-semibold">@br.Book?.Title</div>
                                <small class="text-muted">@br.Book?.Author</small>
                            </td>
                            <td>@br.BorrowDate.ToString("dd/MM/yyyy")</td>
                            <td class="@(br.DueDate < DateTime.UtcNow && br.Status == BorrowStatus.Approved ? "text-danger fw-semibold" : "")">
                                @br.DueDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>@(br.ReturnDate.HasValue ? br.ReturnDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td>
                                @{
                                    var badgeClass = br.Status switch
                                    {
                                        BorrowStatus.Pending => "bg-warning text-dark",
                                        BorrowStatus.Approved => "bg-success",
                                        BorrowStatus.Returned => "bg-secondary",
                                        BorrowStatus.Late => "bg-danger",
                                        BorrowStatus.Rejected => "bg-dark",
                                        _ => "bg-light text-dark"
                                    };
                                    var statusLabel = br.Status switch
                                    {
                                        BorrowStatus.Pending => "Chờ Duyệt",
                                        BorrowStatus.Approved => "Đang Mượn",
                                        BorrowStatus.Returned => "Đã Trả",
                                        BorrowStatus.Late => "Quá Hạn",
                                        BorrowStatus.Rejected => "Từ Chối",
                                        _ => ""
                                    };
                                }
                                <span class="badge @badgeClass">@statusLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
