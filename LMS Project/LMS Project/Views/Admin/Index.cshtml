@using LMS_Project.Models
@{
    ViewData["Title"] = "Bảng Điều Khiển";
    var activeTab = ViewBag.ActiveTab as string ?? "dashboard";
    var books = ViewBag.Books as IEnumerable<Book> ?? Enumerable.Empty<Book>();
    var users = ViewBag.Users as IEnumerable<User> ?? Enumerable.Empty<User>();
    var borrows = ViewBag.Borrows as IEnumerable<BorrowRecord> ?? Enumerable.Empty<BorrowRecord>();
    var categories = ViewBag.Categories as IEnumerable<Category> ?? Enumerable.Empty<Category>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-speedometer2 me-2"></i>Bảng Điều Khiển</h2>
    <span class="text-muted">Xin chào, @User.Identity?.Name</span>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-books display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@ViewBag.TotalBooks</div>
                    <small>Tổng Sách</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-people display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@ViewBag.TotalUsers</div>
                    <small>Tổng Người Dùng</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-warning shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-bookmark display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@ViewBag.TotalBorrows</div>
                    <small>Tổng Lượt Mượn</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-danger shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-bookmark-check display-6"></i>
                <div>
                    <div class="fw-bold fs-4">@ViewBag.ActiveBorrows</div>
                    <small>Đang Mượn</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="adminTabs">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "dashboard" ? "active" : "")"
           asp-controller="Admin" asp-action="Index" asp-route-tab="dashboard">
            <i class="bi bi-graph-up me-1"></i>Tổng Quan
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "books" ? "active" : "")"
           asp-controller="Admin" asp-action="Index" asp-route-tab="books">
            <i class="bi bi-books me-1"></i>Sách
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "categories" ? "active" : "")"
           asp-controller="Admin" asp-action="Index" asp-route-tab="categories">
            <i class="bi bi-tags me-1"></i>Danh Mục
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "borrows" ? "active" : "")"
           asp-controller="Admin" asp-action="Index" asp-route-tab="borrows">
            <i class="bi bi-clock-history me-1"></i>Mượn Sách
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "users" ? "active" : "")"
           asp-controller="Admin" asp-action="Index" asp-route-tab="users">
            <i class="bi bi-people me-1"></i>Người Dùng
        </a>
    </li>
</ul>

<!-- Dashboard Tab -->
@if (activeTab == "dashboard")
{
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold"><i class="bi bi-bar-chart me-2"></i>Tổng Quan Thư Viện</div>
                <div class="card-body">
                    <canvas id="barChart" height="120"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold"><i class="bi bi-pie-chart me-2"></i>Trạng Thái Mượn</div>
                <div class="card-body">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold"><i class="bi bi-clock me-2"></i>Yêu Cầu Mượn Gần Đây</div>
                <div class="card-body table-responsive">
                    <table class="table table-sm align-middle">
                        <thead class="table-light">
                            <tr><th>Người Dùng</th><th>Sách</th><th>Ngày</th><th>Trạng Thái</th><th>Thao Tác</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var b in borrows.Where(x => x.Status == BorrowStatus.Pending).Take(5))
                            {
                                <tr>
                                    <td>@b.User?.FullName</td>
                                    <td>@b.Book?.Title</td>
                                    <td>@b.BorrowDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge bg-warning text-dark">Chờ Duyệt</span></td>
                                    <td>
                                        <form asp-controller="Borrow" asp-action="Approve" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-success btn-sm">Duyệt</button>
                                        </form>
                                        <form asp-controller="Borrow" asp-action="Reject" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-danger btn-sm">Từ Chối</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<!-- Books Tab -->
@if (activeTab == "books")
{
    int bookPage = ViewBag.BookPage;
    int totalBookPages = ViewBag.TotalBookPages;

    <div class="d-flex justify-content-between mb-3">
        <h5 class="fw-semibold">Quản Lý Sách</h5>
        <a asp-controller="Book" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Thêm Sách
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>#</th><th>Ảnh Bìa</th><th>Tiêu Đề</th><th>Tác Giả</th><th>Danh Mục</th><th>SL</th><th>Còn</th><th>Thao Tác</th></tr>
            </thead>
            <tbody>
                @{int bRow = (bookPage - 1) * 10 + 1;}
                @foreach (var book in books)
                {
                    <tr>
                        <td>@(bRow++)</td>
                        <td>
                            <img src="@(book.CoverImagePath ?? "/images/no-cover.svg")"
                                 width="40" height="55" style="object-fit:cover;"
                                 class="rounded" onerror="this.src='/images/no-cover.svg'" />
                        </td>
                        <td class="fw-semibold">@book.Title</td>
                        <td>@book.Author</td>
                        <td><span class="badge bg-info text-dark">@book.Category?.Name</span></td>
                        <td>@book.Quantity</td>
                        <td>
                            <span class="badge @(book.AvailableQuantity > 0 ? "bg-success" : "bg-danger")">
                                @book.AvailableQuantity
                            </span>
                        </td>
                        <td>
                            <a asp-controller="Book" asp-action="Edit" asp-route-id="@book.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-controller="Book" asp-action="Delete" asp-route-id="@book.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa sách này?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalBookPages > 1)
    {
        <nav class="mt-3" aria-label="Phân trang sách">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">Trang @bookPage / @totalBookPages</small>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(bookPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-controller="Admin" asp-action="Index"
                           asp-route-tab="books" asp-route-bookPage="@(bookPage - 1)">
                            <i class="bi bi-chevron-left"></i> Trước
                        </a>
                    </li>
                    @for (int p = 1; p <= totalBookPages; p++)
                    {
                        <li class="page-item @(p == bookPage ? "active" : "")">
                            <a class="page-link" asp-controller="Admin" asp-action="Index"
                               asp-route-tab="books" asp-route-bookPage="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(bookPage >= totalBookPages ? "disabled" : "")">
                        <a class="page-link" asp-controller="Admin" asp-action="Index"
                           asp-route-tab="books" asp-route-bookPage="@(bookPage + 1)">
                            Sau <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    }
}

<!-- Categories Tab -->
@if (activeTab == "categories")
{
    <div class="d-flex justify-content-between mb-3">
        <h5 class="fw-semibold">Quản Lý Danh Mục</h5>
        <a asp-controller="Category" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Thêm Danh Mục
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>#</th><th>Tên</th><th>Mô Tả</th><th>Thao Tác</th></tr>
            </thead>
            <tbody>
                @{int cRow = 1;}
                @foreach (var cat in categories)
                {
                    <tr>
                        <td>@(cRow++)</td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td class="text-muted">@(cat.Description ?? "-")</td>
                        <td>
                            <a asp-controller="Category" asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-controller="Category" asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa danh mục này?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Borrows Tab -->
@if (activeTab == "borrows")
{
    <h5 class="fw-semibold mb-3">Quản Lý Mượn Sách</h5>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>#</th><th>Người Dùng</th><th>Sách</th><th>Ngày Mượn</th><th>Hạn Trả</th><th>Trạng Thái</th><th>Thao Tác</th></tr>
            </thead>
            <tbody>
                @{int brRow = 1;}
                @foreach (var br in borrows)
                {
                    <tr>
                        <td>@(brRow++)</td>
                        <td>@br.User?.FullName<br /><small class="text-muted">@br.User?.Email</small></td>
                        <td class="fw-semibold">@br.Book?.Title</td>
                        <td>@br.BorrowDate.ToString("dd MMM yyyy")</td>
                        <td class="@(br.DueDate < DateTime.UtcNow && br.Status == BorrowStatus.Approved ? "text-danger" : "")">
                            @br.DueDate.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            @{
                                var badgeClass = br.Status switch
                                {
                                    BorrowStatus.Pending => "bg-warning text-dark",
                                    BorrowStatus.Approved => "bg-success",
                                    BorrowStatus.Returned => "bg-secondary",
                                    BorrowStatus.Late => "bg-danger",
                                    BorrowStatus.Rejected => "bg-dark",
                                    _ => "bg-light text-dark"
                                };
                                var statusLabel = br.Status switch
                                {
                                    BorrowStatus.Pending => "Chờ Duyệt",
                                    BorrowStatus.Approved => "Đã Duyệt",
                                    BorrowStatus.Returned => "Đã Trả",
                                    BorrowStatus.Late => "Quá Hạn",
                                    BorrowStatus.Rejected => "Từ Chối",
                                    _ => ""
                                };
                            }
                            <span class="badge @badgeClass">@statusLabel</span>
                        </td>
                        <td>
                            @if (br.Status == BorrowStatus.Pending)
                            {
                                <form asp-controller="Borrow" asp-action="Approve" asp-route-id="@br.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-success btn-sm">Duyệt</button>
                                </form>
                                <form asp-controller="Borrow" asp-action="Reject" asp-route-id="@br.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger btn-sm">Từ Chối</button>
                                </form>
                            }
                            else if (br.Status == BorrowStatus.Approved)
                            {
                                <form asp-controller="Borrow" asp-action="Return" asp-route-id="@br.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-info btn-sm text-white">Trả Sách</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Không có</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Users Tab -->
@if (activeTab == "users")
{
    <h5 class="fw-semibold mb-3">Quản Lý Người Dùng</h5>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>#</th><th>Họ và Tên</th><th>Email</th><th>Vai Trò</th><th>Ngày Tham Gia</th><th>Thao Tác</th></tr>
            </thead>
            <tbody>
                @{int uRow = 1;}
                @foreach (var user in users)
                {
                    <tr>
                        <td>@(uRow++)</td>
                        <td class="fw-semibold">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                <i class="bi @(user.Role == "Admin" ? "bi-shield-fill" : "bi-person-fill") me-1"></i>@user.Role
                            </span>
                        </td>
                        <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (user.Role != "Admin")
                            {
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa người dùng @user.FullName?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Được Bảo Vệ</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    @if (activeTab == "dashboard")
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                var totalBooks = @ViewBag.TotalBooks;
                var totalUsers = @ViewBag.TotalUsers;
                var totalBorrows = @ViewBag.TotalBorrows;
                var activeBorrows = @ViewBag.ActiveBorrows;

                // Bar Chart
                new Chart(document.getElementById("barChart"), {
                    type: "bar",
                    data: {
                        labels: ["Sách", "Người Dùng", "Tổng Lượt", "Đang Mượn"],
                        datasets: [{
                            label: "Thống Kê Thư Viện",
                            data: [totalBooks, totalUsers, totalBorrows, activeBorrows],
                            backgroundColor: ["#0d6efd", "#198754", "#ffc107", "#dc3545"],
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });

                // Pie Chart
                var returned = @(((IEnumerable<BorrowRecord>)ViewBag.Borrows).Count(b => b.Status == BorrowStatus.Returned));
                var pending = @(((IEnumerable<BorrowRecord>)ViewBag.Borrows).Count(b => b.Status == BorrowStatus.Pending));
                var rejected = @(((IEnumerable<BorrowRecord>)ViewBag.Borrows).Count(b => b.Status == BorrowStatus.Rejected));
                var late = @(((IEnumerable<BorrowRecord>)ViewBag.Borrows).Count(b => b.Status == BorrowStatus.Late));

                new Chart(document.getElementById("pieChart"), {
                    type: "doughnut",
                    data: {
                        labels: ["Đang Mượn", "Đã Trả", "Chờ Duyệt", "Từ Chối", "Quá Hạn"],
                        datasets: [{
                            data: [activeBorrows, returned, pending, rejected, late],
                            backgroundColor: ["#198754", "#6c757d", "#ffc107", "#212529", "#dc3545"]
                        }]
                    },
                    options: { responsive: true, plugins: { legend: { position: "bottom" } } }
                });
            })();
        </script>
    }
}
