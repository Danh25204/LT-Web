@model IEnumerable<LMS_Project.Models.Book>
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="hero-section bg-primary text-white rounded-3 p-5 mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold"><i class="bi bi-book-half me-3"></i>Chào Mừng Đến Thư Viện LMS</h1>
            <p class="lead">Khám phá hàng nghìn cuốn sách. Mượn đọc, học hỏi và phát triển.</p>
            <form asp-controller="Home" asp-action="Index" method="get" class="d-flex gap-2 mt-3">
                <input type="text" name="search" class="form-control form-control-lg"
                       placeholder="Tìm kiếm theo tiêu đề, tác giả hoặc ISBN..."
                       value="@ViewBag.Search" id="searchInput" autocomplete="off" />
                <button type="submit" class="btn btn-light btn-lg px-4">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
        <div class="col-md-4 text-center d-none d-md-block">
            <i class="bi bi-journals display-1 opacity-75"></i>
        </div>
    </div>
</div>

<div id="searchResults" class="mb-3 d-none">
    <h5 class="text-muted">Kết quả tìm kiếm trực tiếp:</h5>
    <div id="searchResultsList" class="row row-cols-1 row-cols-md-3 g-4"></div>
</div>

<h4 class="mb-3 fw-semibold">
    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
    {
        <span>Kết quả tìm kiếm: <em>"@ViewBag.Search"</em></span>
    }
    else
    {
        <span>Tất Cả Sách</span>
    }
    <span class="badge bg-secondary ms-2">@ViewBag.TotalCount</span>
</h4>

<div class="row row-cols-1 row-cols-md-3 g-4" id="bookGrid">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm book-card">
                <img src="@(book.CoverImagePath ?? "/images/no-cover.svg")"
                     class="card-img-top book-cover" alt="@book.Title"
                     onerror="this.src='/images/no-cover.svg'" />
                <div class="card-body">
                    <span class="badge bg-info text-dark mb-1">@book.Category?.Name</span>
                    <h6 class="card-title fw-bold">@book.Title</h6>
                    <p class="card-text text-muted small">
                        <i class="bi bi-person me-1"></i>@book.Author
                    </p>
                    @if (book.ISBN != null)
                    {
                        <p class="card-text text-muted small">
                            <i class="bi bi-upc me-1"></i>@book.ISBN
                        </p>
                    }
                    <p class="card-text">
                        <span class="badge @(book.AvailableQuantity > 0 ? "bg-success" : "bg-danger")">
                            @(book.AvailableQuantity > 0 ? $"{book.AvailableQuantity} Còn lại" : "Hết sách")
                        </span>
                    </p>
                </div>
                <div class="card-footer bg-transparent d-flex justify-content-between">
                    <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id"
                       class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i>Chi Tiết
                    </a>
                    @if (!User.IsInRole("Admin") && book.AvailableQuantity > 0)
                    {
                        <form asp-controller="Borrow" asp-action="Borrow" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookId" value="@book.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-bookmark-plus me-1"></i>Mượn
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search display-4 text-muted"></i>
        <p class="mt-3 text-muted">Không tìm thấy sách. Hãy thử từ khóa khác.</p>
    </div>
}

@if (ViewBag.TotalPages > 1)
{
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    string? search = ViewBag.Search as string;

    <nav class="mt-4" aria-label="Phân trang">
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Trang @currentPage / @totalPages
                &nbsp;·&nbsp; @ViewBag.TotalCount sách
            </small>
            <ul class="pagination mb-0">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="Home" asp-action="Index"
                       asp-route-page="@(currentPage - 1)" asp-route-search="@search">
                        <i class="bi bi-chevron-left"></i> Trước
                    </a>
                </li>

                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" asp-controller="Home" asp-action="Index"
                           asp-route-page="@p" asp-route-search="@search">@p</a>
                    </li>
                }

                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-controller="Home" asp-action="Index"
                       asp-route-page="@(currentPage + 1)" asp-route-search="@search">
                        Sau <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    </nav>
}

@section Scripts {
    <script src="~/js/search.js" asp-append-version="true"></script>
}
