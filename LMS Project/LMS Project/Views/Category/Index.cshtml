@model IEnumerable<LMS_Project.Models.Category>
@{
    ViewData["Title"] = "Danh Mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-tags me-2"></i>Danh Mục</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Thêm Danh Mục
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên</th>
                <th>Mô Tả</th>
                <th>Số Sách</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @{int i = 1;}
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@(i++)</td>
                    <td class="fw-semibold">@cat.Name</td>
                    <td class="text-muted">@(cat.Description ?? "-")</td>
                    <td><span class="badge bg-info text-dark">@cat.Books.Count</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-warning btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa danh mục này?');">/
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
