@model IEnumerable<LMS_Project.Models.BorrowRecord>
@using LMS_Project.Models
@{
    ViewData["Title"] = "Lịch Sử Mượn Sách";
}

<h2 class="fw-bold mb-4"><i class="bi bi-clock-history me-2"></i>Lịch Sử Mượn Sách</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bookmark display-4 text-muted"></i>
        <p class="mt-3 text-muted">Bạn chưa mượn sách nào.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-books me-1"></i>Xem Sách
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Tên Sách</th>
                    <th>Ngày Mượn</th>
                    <th>Hạn Trả</th>
                    <th>Ngày Trả</th>
                    <th>Trạng Thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{int row = 1;}
                @foreach (var record in Model)
                {
                    var isOverdue = record.Status == BorrowStatus.Approved && record.DueDate < DateTime.UtcNow;
                    var overdueDays = isOverdue ? (int)(DateTime.UtcNow - record.DueDate).TotalDays : 0;
                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td>@(row++)</td>
                        <td>
                            <div class="fw-semibold">@record.Book?.Title</div>
                            <small class="text-muted">@record.Book?.Author</small>
                            @if (isOverdue)
                            {
                                <br /><small class="text-danger fw-semibold"><i class="bi bi-exclamation-triangle me-1"></i>Quá hạn @overdueDays ngày</small>
                            }
                        </td>
                        <td>@record.BorrowDate.ToString("dd MMM yyyy")</td>
                        <td class="@(record.DueDate < DateTime.UtcNow && record.Status == BorrowStatus.Approved ? "text-danger fw-bold" : "")">
                            @record.DueDate.ToString("dd MMM yyyy")
                        </td>
                        <td>@(record.ReturnDate?.ToString("dd MMM yyyy") ?? "-")</td>
                        <td>
                            @{
                                var (badgeClass, icon, label) = record.Status switch
                                {
                                    BorrowStatus.Pending => ("bg-warning text-dark", "bi-hourglass", "Chờ Duyệt"),
                                    BorrowStatus.Approved => isOverdue
                                        ? ("bg-danger", "bi-exclamation-circle", "Đang Quá Hạn")
                                        : ("bg-success", "bi-check-circle", "Đã Duyệt"),
                                    BorrowStatus.Returned => ("bg-secondary", "bi-book", "Đã Trả"),
                                    BorrowStatus.Late => ("bg-danger", "bi-exclamation-circle", "Trả Muộn"),
                                    BorrowStatus.Rejected => ("bg-dark", "bi-x-circle", "Từ Chối"),
                                    _ => ("bg-light text-dark", "bi-question", "Khác")
                                };
                            }
                            <span class="badge @badgeClass">
                                <i class="bi @icon me-1"></i>@label
                            </span>
                        </td>
                        <td>
                            @if (record.Status == BorrowStatus.Approved)
                            {
                                <form asp-controller="Borrow" asp-action="UserReturn" asp-route-id="@record.Id"
                                      method="post" onsubmit="return confirm('Xác nhận trả sách này?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-book me-1"></i>Trả Sách
                                    </button>
                                </form>
                                @if (!isOverdue && record.ExtendCount < 1)
                                {
                                    <form asp-controller="Borrow" asp-action="Extend" asp-route-id="@record.Id"
                                          method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('Gia hạn thêm 7 ngày?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-calendar-plus me-1"></i>Gia Hạn
                                        </button>
                                    </form>
                                }
                                @if (record.ExtendCount >= 1)
                                {
                                    <span class="badge bg-secondary ms-1" title="Đã gia hạn 1 lần">
                                        <i class="bi bi-check me-1"></i>Đã gia hạn
                                    </span>
                                }
                            }
                            @if (record.Status == BorrowStatus.Pending)
                            {
                                <form asp-controller="Borrow" asp-action="Cancel" asp-route-id="@record.Id"
                                      method="post" onsubmit="return confirm('Bạn có chắc muốn hủy yêu cầu này?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-x-circle me-1"></i>Hủy Yêu Cầu
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
