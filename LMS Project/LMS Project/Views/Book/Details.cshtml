@model LMS_Project.Models.Book
@using LMS_Project.Models
@{
    ViewData["Title"] = Model.Title;
    var reviews = ViewBag.Reviews as IEnumerable<BookReview> ?? Enumerable.Empty<BookReview>();
    var avgRating = (double)(ViewBag.AvgRating ?? 0.0);
    var canReview = (bool)(ViewBag.CanReview ?? false);
    var userReview = ViewBag.UserReview as BookReview;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Book" asp-action="Index">Sách</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-4">
        <img src="@(Model.CoverImagePath ?? "/images/no-cover.svg")"
             class="img-fluid rounded shadow" alt="@Model.Title"
             onerror="this.src='/images/no-cover.svg'" style="max-height:400px; object-fit:cover; width:100%;" />
    </div>
    <div class="col-md-8">
        <span class="badge bg-info text-dark mb-2">@Model.Category?.Name</span>
        <h2 class="fw-bold">@Model.Title</h2>

        <!-- Rating tổng hợp -->
        @if (reviews.Any())
        {
            <div class="mb-2">
                @for (int s = 1; s <= 5; s++)
                {
                    <i class="bi @(s <= Math.Round(avgRating) ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                }
                <span class="ms-1 text-muted small">@avgRating.ToString("0.0") / 5 (@reviews.Count() đánh giá)</span>
            </div>
        }
        <p class="text-muted"><i class="bi bi-person me-1"></i><strong>Tác giả:</strong> @Model.Author</p>
        @if (Model.ISBN != null)
        {
            <p class="text-muted"><i class="bi bi-upc me-1"></i><strong>ISBN:</strong> @Model.ISBN</p>
        }
        <p><strong>Tổng số:</strong> @Model.Quantity</p>
        <p>
            <strong>Còn lại:</strong>
            <span class="badge @(Model.AvailableQuantity > 0 ? "bg-success" : "bg-danger") fs-6">
                @Model.AvailableQuantity / @Model.Quantity
            </span>
        </p>
        @if (Model.Description != null)
        {
            <hr />
            <h5>Mô Tả</h5>
            <p class="text-muted">@Model.Description</p>
        }
        <hr />
        <div class="d-flex gap-2 flex-wrap">
            @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin") && Model.AvailableQuantity > 0)
            {
                <form asp-controller="Borrow" asp-action="Borrow" method="post" id="borrowForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary" id="borrowBtn">
                        <i class="bi bi-bookmark-plus me-1"></i>Mượn Sách Này
                    </button>
                </form>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i>Chỉnh Sửa
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Bạn có chắc muốn xóa sách này?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Xóa
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<!-- ===== REVIEWS SECTION ===== -->
<div class="mt-5">
    <h4 class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Đánh Giá &amp; Nhận Xét</h4>

    @if (!reviews.Any())
    {
        <p class="text-muted fst-italic">Chưa có đánh giá nào cho cuốn sách này.</p>
    }

    <!-- Form đánh giá -->
    @if (canReview && userReview == null && !User.IsInRole("Admin"))
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-pencil-square me-1"></i>Viết Đánh Giá Của Bạn
            </div>
            <div class="card-body">
                <form asp-controller="Book" asp-action="AddReview" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Xếp hạng <span class="text-danger">*</span></label>
                        <div class="star-rating">
                            @for (int i = 5; i >= 1; i--)
                            {
                                <input type="radio" id="star@(i)" name="rating" value="@i" required />
                                <label for="star@(i)" title="@i sao"><i class="bi bi-star-fill"></i></label>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nhận xét (tuỳ chọn)</label>
                        <textarea name="comment" class="form-control" rows="3" maxlength="1000"
                                  placeholder="Chia sẻ cảm nhận của bạn về cuốn sách này..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Gửi Đánh Giá
                    </button>
                </form>
            </div>
        </div>
    }
    else if (userReview != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-1"></i>
            Bạn đã đánh giá sách này
            @for (int s = 1; s <= 5; s++)
            {
                <i class="bi @(s <= userReview.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
            }
        </div>
    }
    else if (!User.IsInRole("Admin") && User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>
            Bạn cần <strong>mượn và trả sách</strong> trước khi có thể đánh giá.
        </div>
    }

    <!-- Danh sách reviews -->
    @foreach (var review in reviews)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@review.User?.FullName</strong>
                        <div class="my-1">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <i class="bi @(s <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")" style="font-size:0.9rem;"></i>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                        {
                            <p class="mb-0 text-muted">@review.Comment</p>
                        }
                    </div>
                    <small class="text-muted text-nowrap">@review.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</small>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .star-rating { display: flex; flex-direction: row-reverse; justify-content: flex-end; gap: 4px; }
    .star-rating input { display: none; }
    .star-rating label { font-size: 1.6rem; color: #ccc; cursor: pointer; transition: color .15s; }
    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label { color: #ffc107; }
</style>
