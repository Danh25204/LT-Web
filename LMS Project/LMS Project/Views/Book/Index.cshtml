@model IEnumerable<LMS_Project.Models.Book>
@{
    ViewData["Title"] = "Sách";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-books me-2"></i>Danh Mục Sách</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Thêm Sách Mới
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm book-card">
                <img src="@(book.CoverImagePath ?? "/images/no-cover.svg")"
                     class="card-img-top book-cover" alt="@book.Title"
                     onerror="this.src='/images/no-cover.svg'" />
                <div class="card-body">
                    <span class="badge bg-info text-dark mb-1">@book.Category?.Name</span>
                    <h6 class="card-title fw-bold">@book.Title</h6>
                    <p class="card-text text-muted small"><i class="bi bi-person me-1"></i>@book.Author</p>
                    <span class="badge @(book.AvailableQuantity > 0 ? "bg-success" : "bg-danger")">
                        @(book.AvailableQuantity > 0 ? $"{book.AvailableQuantity} Còn lại" : "Hết sách")
                    </span>
                </div>
                <div class="card-footer bg-transparent d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i>Chi Tiết
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-outline-warning btn-sm">
                            <i class="bi bi-pencil me-1"></i>Sửa
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-4 text-muted"></i>
        <p class="mt-2 text-muted">Chưa có sách nào trong thư viện.</p>
    </div>
}
